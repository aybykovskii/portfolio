---
import Portfolio from '@/containers/Portfolio/Portfolio.astro'
import Layout from '@/layouts/Layout.astro'
import { lang as langs } from '@/types'

export const prerender = true
export function getStaticPaths () {
  return langs.options.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params
---

<Layout title="Portfolio" lang={lang}>
  <Portfolio lang={lang} />
</Layout>
