const t = content[lang] ?? content.en
---

<Layout title={t.title} description={t.description} noindex>
  <div class="max-w-3xl mx-auto px-6">
    <a
      href={`/${lang}`}
      class="inline-flex items-center gap-2 text-base-content/60 hover:text-base-content mb-8 transition-colors"
    >
      ← {commonTranslations?.actions.back}
    </a>

    <h1 class="text-3xl font-bold mb-2">{t.title}</h1>
    <p class="text-base-content/50 text-sm mb-10">{t.lastUpdated}</p>

    <div class="space-y-8">
      {t.sections.map((section) => (
        <section>
          <h2 class="text-lg font-semibold mb-2">{section.heading}</h2>
          <div class="text-base-content/70 leading-relaxed whitespace-pre-line">{section.body}</div>
        </section>
      ))}
    </div>
  </div>
</Layout>
