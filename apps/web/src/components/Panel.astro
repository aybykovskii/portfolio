---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { Calendar, MapPin } from 'lucide-react'

import type { Lang } from '@/types'
import { getCdnImageUrl, getProgressPercent } from '@/utils'

import { Bar } from './Bar'

interface Props {
  lang: Lang
  languages?: CollectionEntry<'languages'>[]
  skills?: CollectionEntry<'technologies'>[]
}

const { languages, skills, lang } = Astro.props
const { commonTranslations, bio } = Astro.locals

const { avatar, name, position, location } = bio

const subInfo = [
  {
    icon: Calendar,
    label: commonTranslations.status.available,
  },
  {
    icon: MapPin,
    label: location,
  },
]
---
<aside
  class:list={[
    'flex flex-col gap-3 w-full',
    'sm:grid sm:grid-cols-2 sm:grid-rows-5 sm:gap-6',
    'xl:flex xl:flex-col',
  ]}
>
  <section class:list={['panel-section sm:col-span-1 sm:row-span-5']}>
    <div class="avatar avatar-online">
      <div class="aspect-square w-32 rounded-full">
        <Image src={getCdnImageUrl(avatar)} alt={name} inferSize />
      </div>
    </div>

    <h3 class="font-semibold text-lg">{name}</h3>
    <span class="text-sm">{position}</span>

    {subInfo.map(({ icon: Icon, label }) => (
      <span class="flex items-center gap-1 text-base-content/60 text-sm">
        <Icon size={14} />
        {label}
      </span>
    ))}
  </section>

  <section class:list={['panel-section sm:col-span-1 sm:row-span-1']}>
    <ul class="flex justify-evenly w-full gap-4">
      {Object.values(bio.contacts).map(({ class: className, value }) => (
        <a href={value} class="hover:text-primary transition-colors duration-300">
          <i class:list={[className, 'fa-lg']} />
        </a>
      ))}
    </ul>
  </section>

  <section class:list={['panel-section sm:col-span-1 sm:row-span-3']}>
    <ul class="flex flex-col w-full gap-2">
      {languages?.map(({ data: language }) => (
        <Bar
          title={language.translations[lang].name}
          progress={getProgressPercent(language.level * 2)}
        />
      ))}
    </ul>
  </section>

  <section class="sm:col-span-1 sm:row-span-1">
    <ul class="flex flex-wrap justify-evenly gap-2">
      {skills?.filter(({ data: skill }) => skill.isMain).map((skill) => (
        <li class="badge badge-primary">{skill.data.name}</li>
      ))}
    </ul>
  </section>
</aside>
