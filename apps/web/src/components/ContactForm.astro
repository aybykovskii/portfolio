---
import { MailCheck } from 'lucide-react'

const { commonTranslations } = Astro.locals
---

<section id="contact" class="main-section">
  <h2 class="font-semibold text-3xl">
    {commonTranslations.sections.contact}
  </h2>

  <form id="contact-form" class="flex flex-col gap-4" novalidate>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <fieldset class="fieldset">
        <legend class="fieldset-legend">{commonTranslations.contact.name}</legend>
        <input
          type="text"
          name="name"
          required
          placeholder={commonTranslations.contact.namePlaceholder}
          class="input input-bordered w-full"
        />
      </fieldset>

      <fieldset class="fieldset">
        <legend class="fieldset-legend">Email</legend>
        <input
          type="email"
          name="email"
          required
          placeholder="hello@example.com"
          class="input input-bordered w-full"
        />
      </fieldset>
    </div>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">{commonTranslations.contact.message}</legend>
      <textarea
        name="message"
        required
        rows="5"
        placeholder={commonTranslations.contact.messagePlaceholder}
        class="textarea textarea-bordered w-full resize-none"
      ></textarea>
    </fieldset>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div id="contact-success" class="flex items-center gap-2 text-success font-medium hidden">
        <MailCheck size={24} />

        <span>
          <span class="block">{commonTranslations.contact.successTitle}</span>
          <span class="block text-sm font-normal text-base-content/60">{commonTranslations.contact.successText}</span>
        </span>
      </div>

      <button type="submit" class="btn btn-primary rounded-full px-8 col-span-1 sm:col-start-2">
        <span class="loading loading-spinner loading-xs hidden"></span>
        {commonTranslations.contact.send}
      </button>
    </div>
  </form>
</section>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement | null
const success = document.getElementById('contact-success')

form?.addEventListener('submit', (e) => {
  e.preventDefault()
  if (!form.checkValidity()) {
    form.reportValidity()
    return
  }

  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
  const loader = btn.querySelector('span.loading-spinner') as HTMLSpanElement
  btn.disabled = true
  loader.classList.remove('hidden')

  // TODO: wire up a real backend (e.g. Formspree, Resend)
  setTimeout(() => {
    form.reset()
    btn.disabled = false
    loader.classList.add('hidden')
    success?.classList.remove('hidden')

    setTimeout(() => success?.classList.add('hidden'), 5000)
  }, 800)
})
function initContactForm () {
}

initContactForm()
document.addEventListener('astro:page-load', initContactForm)
</script>
