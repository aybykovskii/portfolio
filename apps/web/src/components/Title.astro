---
const { bio: { highlight, position } } = Astro.locals

const isStartsWithHighlight = position.startsWith(highlight)
const restPosition = position.replace(highlight, '')
---
<h1 class="flex flex-col flex-wrap gap-3.5 w-full" style="container-type: inline-size">
  {isStartsWithHighlight ? (
    <>
      <span class="portfolio-title-main">{highlight}</span>
      <span class="portfolio-title-rest">{restPosition}</span>
    </>
  ) : (
     <>
       <span class="portfolio-title-rest">{restPosition}</span>
       <span class="portfolio-title-main">{highlight}</span>
     </>
   )}
</h1>
