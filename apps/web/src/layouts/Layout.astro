---
import { Font } from 'astro:assets'
import { ClientRouter } from 'astro:transitions'

import LangToggle from '@/components/LangToggle.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'

import { Logo } from './Logo'
import '../styles/root.css'
import '../styles/reset.css'

const { commonTranslations, lang } = Astro.locals

const titlesByLang = {
  en: 'Aleksei Bykovskii',
  ru: 'Алексей Быковский',
  es: 'Aleksei Bykovskii',
}

const descriptionsByLang = {
  en: 'Aleksei Bykovskii Portfolio',
  ru: 'Портфолио Алексея Быковского',
  es: 'Portafolio de Aleksei Bykovskii',
}

interface Props {
  /** Заголовок страницы (до 60 символов). По умолчанию: "Daaspil" */
  title?: string
  /** Описание страницы для поисковиков и соцсетей (150–160 символов) */
  description?: string
  /** URL изображения для Open Graph / Twitter Card (рекомендуется 1200×630) */
  ogImage?: string
  /** Канонический URL страницы. По умолчанию — текущий URL */
  canonical?: string
  /** Скрыть страницу от индексации (для админки и т.п.) */
  noindex?: boolean
}

const {
  title = titlesByLang[lang],
  description = descriptionsByLang[lang],
  ogImage = '/og.jpeg',
  canonical,
  noindex = false,
} = Astro.props

const siteName = 'Aleksei Bykovskii'
const fullTitle = title === siteName ? title : `${title} | ${siteName}`
const canonicalUrl = canonical ?? Astro.url.href
const ogImageUrl = new URL(ogImage, Astro.url.origin).href

const ogLocale = lang === 'ru' ? 'ru_RU' : lang === 'es' ? 'es_ES' : 'en_US'

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${Astro.url.origin}/#organization`,
  name: siteName,
  url: Astro.url.origin,
  logo: new URL('/favicon.svg', Astro.url.origin).href,
  sameAs: ['https://www.linkedin.com/in/aybykovskii/', 'https://github.com/aybykovskii'],
  description,
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: Astro.url.origin,
  description,
  publisher: { '@id': `${Astro.url.origin}/#organization` },
}

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${Astro.url.origin}/#person`,
  name: siteName,
  url: Astro.url.origin,
  jobTitle: 'Senior Frontend Engineer',
  sameAs: ['https://www.linkedin.com/in/aybykovskii/', 'https://github.com/aybykovskii'],
  worksFor: { '@id': `${Astro.url.origin}/#organization` },
}
---

<!DOCTYPE html>
<html lang={lang} data-theme="dracula">
  <head>
    <script is:inline>
    const stored = JSON.parse(localStorage.getItem('theme') || 'null')
    document.documentElement.dataset.theme = stored === 'lofi' ? 'lofi' : 'dracula'
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <Font cssVariable="--font-inter" preload />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-85CRHPDX8E"></script>
    <script lang="js">
    window.dataLayer = window.dataLayer || []
    function gtag () {
      dataLayer.push(arguments)
    }
    gtag('js', new Date())
    gtag('config', 'G-85CRHPDX8E')
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <header class="sticky top-4 z-10 flex items-start justify-between px-4">
      <div class="flex items-center gap-2 header-island">
        <button class="w-8 h-8 text-base-content btn btn-ghost btn-circle" aria-label="Home">
          <Logo />
        </button>
        <button id="scroll-to-contact" class="btn btn-primary btn-sm rounded-full">
          {commonTranslations?.actions.contactMe}
        </button>
      </div>

      <div class="flex gap-2 header-island">
        <ThemeToggle />
        <LangToggle />
      </div>
    </header>

    <main>
      <ClientRouter />
      <slot lang={lang} />
    </main>

    <footer class="mt-16 border-t border-base-content/10">
      <div class="flex items-center justify-between px-6 py-4 text-base-content/60 text-sm sm:text-base">
        <span>© {new Date().getFullYear()} Aleksei Bykovskii</span>
        <span>All rights reserved</span>
      </div>
    </footer>

    <script>
    const contactButton = document.getElementById('scroll-to-contact')
    const contactForm = document.getElementById('contact-form')

    contactButton?.addEventListener('click', () => {
      contactForm?.scrollIntoView({ behavior: 'smooth' })
    })
    </script>

    <script>
    if ('modelContext' in navigator) {
      // @ts-ignore
      navigator.modelContext.provideContext({
        tools: [
          {
            name: 'contact',
            description: 'Send a contact message to Aleksei Bykovskii via the portfolio contact form.',
            inputSchema: {
              type: 'object',
              required: ['name', 'email', 'message'],
              properties: {
                name: { type: 'string', description: "Sender's full name" },
                email: { type: 'string', format: 'email', description: "Sender's email address" },
                message: { type: 'string', description: 'Message body' },
              },
            },
            execute: async ({ name, email, message }: { name: string; email: string; message: string }) => {
              const body = new FormData()
              body.append('name', name)
              body.append('email', email)
              body.append('message', message)

              const res = await fetch('/_actions/contact', { method: 'POST', body })
              if (!res.ok) throw new Error(`Request failed: ${res.status}`)
              return { success: true }
            },
          },
          {
            name: 'get_portfolio_info',
            description:
              'Get structured information about Aleksei Bykovskii — bio, experience, projects, and skills — as Markdown.',
            inputSchema: { type: 'object', properties: {} },
            execute: async () => {
              const res = await fetch('/llms.txt')
              return { content: await res.text() }
            },
          },
        ],
      })
    }
    </script>
  </body>
</html>
