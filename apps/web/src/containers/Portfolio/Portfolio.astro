---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import { getEntries } from 'astro:content'
import { PROJECT_DETAILS_ENABLED } from 'astro:env/server'

import { bio } from '@/collections/types'
import ContactForm from '@/components/ContactForm.astro'
import ExperienceCard from '@/components/ExperienceCard.astro'
import Panel from '@/components/Panel.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import Title from '@/components/Title.astro'
import type { Lang } from '@/types'
import { getTranslated } from '@/utils'

export const prerender = true

interface Props {
  lang: Lang
}

const { lang } = Astro.props

const projects = await getCollection('projects')
const experiences = await getCollection('experiences')
const technologies = await getCollection('technologies')
const languages = await getCollection('languages')
const translatedBio = getTranslated(bio, lang)
const commonTranslations = Astro.locals.commonTranslations

const technologiesByExperiences: Record<string, CollectionEntry<'technologies'>[]> = {}

for (const experience of experiences) {
  const list = await getEntries(experience.data.technologies)
  technologiesByExperiences[experience.data.slug] = list.filter(Boolean)
}
---

<div class="grid grid-cols-1 xl:grid-cols-[1fr_300px] gap-8 xl:gap-12 text-base-content">
  <section class="order-1 xl:col-start-1 xl:row-start-1 flex flex-col items-start gap-6">
    <h1 class="flex flex-wrap gap-3.5">
      <Title lang={lang} bio={translatedBio} />
    </h1>
    <p class="text-base-content/60 font-normal text-lg leading-relaxed">
      {bio.translations[lang].description}
    </p>
  </section>

  <div class="order-2 xl:col-start-2 xl:row-start-1 xl:row-span-2 xl:sticky xl:top-[82px] xl:self-start">
    <Panel languages={languages} skills={technologies} lang={lang} />
  </div>

  <section class="order-3 xl:col-start-1 xl:row-start-2 flex flex-col gap-6 min-w-0">
    <section class="flex flex-col gap-4">
      <h2 class="mb-6 text-base-content font-semibold text-3xl">
        {commonTranslations.sections.experience}
      </h2>
      {experiences?.map(({ data: experience }) => (
        <ExperienceCard
          lang={lang}
          commonTranslations={commonTranslations}
          experience={experience}
          technologies={technologiesByExperiences[experience.slug] ?? []}
        />
      ))}
    </section>

    <section class="flex flex-col gap-4">
      <h2 class="mb-6 text-base-content font-semibold text-3xl">
        {commonTranslations.sections.skills}
      </h2>
      <ul class="flex flex-wrap gap-4">
        {technologies?.map(({ data: technology }) => (
          <li>
            <span class="badge badge-primary badge-soft badge-lg gap-2">
              <img
                width={16}
                height={16}
                src={`https://cdn.simpleicons.org/${technology.icon}/default`}
                alt={technology.name}
              />
              {technology.name}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <section class="flex flex-col gap-4">
      <h2 class="mb-6 text-base-content font-semibold text-3xl">
        {commonTranslations.sections.projects}
      </h2>
      {projects?.map(({ data: project }) => (
        <ProjectCard
          lang={lang}
          project={project}
          commonTranslations={commonTranslations}
          isProjectDetailsEnabled={PROJECT_DETAILS_ENABLED}
        />
      ))}
    </section>

    <ContactForm lang={lang} commonTranslations={commonTranslations} />
  </section>
</div>
